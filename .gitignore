# pyenv
#   For a library or app, you might want to share your .python-version if you're
#   using pyenv and micro-managing it.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used with a library, you should NOT include it.
#https://pipenv.pypa.io/en/latest/advanced/#pipenv-and-version-control
#Pipfile.lock

# poetry
#   Similarly, the recommended best-practices to guess is to include poetry.lock in version control.
#   https://python-poetry.org/docs/basic-usage/#commit-your-poetrylock-file-to-version-control
#poetry.lock

# pdm
#   https://pdm.fming.dev/#version-control
.pdm.toml
.pdm-plugins/

